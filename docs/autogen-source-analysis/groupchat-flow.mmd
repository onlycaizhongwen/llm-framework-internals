flowchart TD
    Run["Team.run_stream"] --> Init["_init(runtime)"]
    Init --> Participants["注册 ChatAgentContainer<br/>每个 participant 一个 topic"]
    Participants --> Manager["注册 GroupChatManager"]
    Manager --> Subs["添加 group / participant / output subscriptions"]
    Subs --> Start["publish GroupChatStart"]
    Start --> ManagerStart["manager.handle_start"]
    ManagerStart --> Select["select_speaker"]
    Select --> AgentTopic["向 speaker topic 发布请求"]
    AgentTopic --> Container["ChatAgentContainer<br/>调用真实 ChatAgent"]
    Container --> AgentResponse["发布 GroupChatAgentResponse"]
    AgentResponse --> ManagerResponse["manager.handle_agent_response"]
    ManagerResponse --> Term{"termination / max_turns?"}
    Term -->|否| Select
    Term -->|是| Stop["GroupChatTermination<br/>TaskResult"]
