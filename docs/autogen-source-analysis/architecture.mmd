flowchart TB
    User["调用方<br/>应用代码 / Studio / CLI"] --> AgentChat["AgentChat<br/>AssistantAgent / Teams"]
    User --> Core["Core<br/>Message / Agent / Runtime"]
    AgentChat --> BaseChatAgent["BaseChatAgent<br/>run / run_stream"]
    BaseChatAgent --> Assistant["AssistantAgent<br/>模型调用 + 工具循环"]
    AgentChat --> Teams["Teams<br/>RoundRobin / Selector / Swarm"]
    Teams --> GroupChat["BaseGroupChat<br/>团队运行入口"]
    GroupChat --> Manager["GroupChatManager<br/>选择下一位发言者"]
    GroupChat --> Runtime["SingleThreadedAgentRuntime<br/>队列 + 消息投递"]
    Core --> Runtime
    Core --> Routed["RoutedAgent<br/>@message_handler / @event / @rpc"]
    Core --> ModelClient["ChatCompletionClient<br/>模型抽象"]
    Core --> Tool["BaseTool / Workbench<br/>工具抽象"]
    Assistant --> ModelClient
    Assistant --> Tool
    Manager --> ModelClient
    Ext["autogen-ext<br/>OpenAI / MCP / Code Exec"] --> ModelClient
    Ext --> Tool
    Studio["AutoGen Studio"] --> AgentChat
