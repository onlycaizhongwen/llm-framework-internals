flowchart TD
    Start([agent.run / run_stream]) --> Normalize["BaseChatAgent<br/>任务转 TextMessage"]
    Normalize --> Stream["AssistantAgent.on_messages_stream"]
    Stream --> Memory["更新 memory<br/>写入 model_context"]
    Memory --> CallLLM["_call_llm<br/>ChatCompletionClient.create"]
    CallLLM --> ModelResult["_process_model_result"]
    ModelResult --> ToolCall{"模型返回工具调用?"}
    ToolCall -->|否| Final["TextMessage / StructuredMessage"]
    ToolCall -->|是| Execute["_execute_tool_calls<br/>Workbench / Tool"]
    Execute --> AddResult["FunctionExecutionResultMessage<br/>写回 model_context"]
    AddResult --> Reflect{"reflect_on_tool_use?"}
    Reflect -->|是| ReflectFlow["_reflect_on_tool_use_flow<br/>再调一次模型"]
    Reflect -->|否| Summary["ToolCallSummaryMessage"]
    ReflectFlow --> Final
    Final --> Response["Response"]
    Summary --> Response
    Response --> TaskResult["TaskResult"]
